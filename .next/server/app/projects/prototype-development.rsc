5:["$","$L10",null,{"project":{"_id":"c6606bde-1c09-4616-b6c0-d9c475979aa5","body":{"conclusion":"The project validated that rigorous functional testing early in the development cycle prevents costly redesigns at scale. The methodology developed here is directly transferable to other consumer packaging formats.","methodology":"Multiple neck-finish geometries were evaluated using tolerance stack-up analysis. Prototype seals were pressure-tested at 0.5, 1.0, and 1.5 bar to simulate distribution stresses. Drop tests from 1.2 m onto rigid surfaces assessed deformation behavior.","overview":"This product development project explored the engineering requirements of a consumer shampoo bottle, from initial concept through prototype evaluation. Emphasis was placed on dispensing mechanism reliability, structural integrity under transit loads, and cap-to-neck seal performance.","results":"A 28mm thread pitch with a secondary induction seal achieved zero leakage across all pressure tests. Wall thickness optimization reduced material usage by 12% while maintaining structural ratings. The dispensing pump achieved a consistent 1.8 ml/stroke output."},"category":"Product Development","description":"End-to-end product engineering exploration including packaging functionality analysis and leak testing concepts.","featured":false,"id":"c6606bde-1c09-4616-b6c0-d9c475979aa5","images":[{"alt":"Prototype iteration sketches","asset":{"_ref":"image-6913efea4d8b979303d52ce132c5b36c2ff88121-4032x3024-jpg","_type":"reference"},"src":"https://cdn.sanity.io/images/c2t45jcn/production/6913efea4d8b979303d52ce132c5b36c2ff88121-4032x3024.jpg"},{"alt":"Leak testing setup","asset":{"_ref":"image-b1495526d0422ec62ce9b522af5729139c385d72-3148x2100-jpg","_type":"reference"},"src":"https://cdn.sanity.io/images/c2t45jcn/production/b1495526d0422ec62ce9b522af5729139c385d72-3148x2100.jpg"},{"alt":"Final prototype","asset":{"_ref":"image-66bbe3e70d50ccc7f68ca5172fbddf7059bb9e21-4032x3024-jpg","_type":"reference"},"src":"https://cdn.sanity.io/images/c2t45jcn/production/66bbe3e70d50ccc7f68ca5172fbddf7059bb9e21-4032x3024.jpg"}],"slug":"prototype-development","title":"Prototype Development","year":"2024"}}]
